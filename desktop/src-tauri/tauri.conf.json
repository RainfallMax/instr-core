{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "instr-core",
  "version": "0.2.0",
  "identifier": "com.instrcore.app",
  "build": {
    "beforeDevCommand": "cd ../.. && cd desktop && npm run dev",
    "beforeBuildCommand": "cd ../.. && cd desktop && npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "instr-core",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
